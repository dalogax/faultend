# Environment Configuration
SAMPLE_DATA=true
ROOT_DOMAIN=localhost
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://localhost:5432/faultend

# Session (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-64-character-string-for-production

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Development (set to true to enable /auth/dev-login for local testing)
MOCK_AUTH_ENABLED=true

# PostHog Analytics (optional — leave blank to disable analytics entirely)
# Get your project key from posthog.com → Project settings → Project API key
POSTHOG_PUBLIC_KEY=
# EU region: https://eu.i.posthog.com | US region: https://us.i.posthog.com | self-hosted: your own URL
# Note: the frontend HTML also has the host hardcoded in the PostHog snippet — update both if you change region.
POSTHOG_HOST=https://eu.i.posthog.com

# Prometheus Metrics (optional — set to true to expose /metrics endpoint)
# Prometheus should be configured to scrape https://app.faultend.com/metrics
METRICS_ENABLED=false
# Optional bearer token to protect the /metrics endpoint (recommended in production)
# Generate with: openssl rand -hex 32
METRICS_TOKEN=
