{
  "name": "Faultend",
  "version": "0.1.0",
  "description": "Lightweight proxy tool for testing application resilience",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node scripts/test-with-docker.js",
    "test:direct": "node tests/backend.test.js && sleep 2 && playwright test",
    "migrate": "node src/db/migrate.js",
    "migrate:reset": "node src/db/migrate.js reset"
  },
  "keywords": [
    "proxy",
    "testing",
    "mock",
    "resilience"
  ],
